# ── liteScope environment variables ───────────────────────────────────────────
# Copy to .env and fill in real values.

# MQTT broker credentials — used by Mosquitto and must match config.json
MQTT_USERNAME=litescope
MQTT_PASSWORD=change_me_please

# Traefik (docker-compose.traefik.yml only) — domain Traefik routes to liteScope
DOMAIN=litescope.example.com

# Public frontend origin — used to generate sitemap.xml and robots.txt.
VITE_SITE_URL=https://litescope.example.com

# Umami analytics (optional) — set both to enable the tracking script
VITE_UMAMI_URL=
VITE_UMAMI_WEBSITE_ID=

# Observer setup card shown on the Home page.
# Set these to the values your MQTT broker is configured with so the card shows correct details.
VITE_MQTT_HOST=
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
