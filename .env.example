# ── liteScope stack environment variables ─────────────────────────────────────
# Copy to .env and fill in real values before running `docker compose up`.
# This file is safe to commit. The .env file must NOT be committed.

# MQTT broker credentials.
# The Mosquitto container creates its password file from these on first start.
# The backend config.json must use the same values in mqttSources[].username/password.
MQTT_USERNAME=litescope
MQTT_PASSWORD=change_me_please
