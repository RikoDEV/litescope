# ── liteScope frontend environment variables ──────────────────────────────────
# Copy to .env.local for local overrides or .env.production for prod builds.
# All VITE_* variables are baked into the bundle at build time by Vite.
# ⚠  Never commit secrets here — this file is safe to commit as-is.

# Base URL of the liteScope backend (protocol + host, no trailing slash).
# Leave empty to use relative URLs, which works when:
#   • Running `pnpm dev` (Vite proxy forwards /api and /ws to localhost:3000)
#   • Serving from the same origin as the backend (Caddy / nginx reverse proxy)
#
# Set to a full URL only when the frontend and backend are on different origins:
#   VITE_API_URL=https://litescope.example.com
VITE_API_URL=
